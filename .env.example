# Copy to .env and fill in your token. .env is gitignored.
# The Notion CLI (ntn) reads NOTION_API_TOKEN and uses it instead of keychain auth.
# Use a Personal Access Token (PAT) that acts as your user — it inherits your
# access and reaches content that integration-bots can't (e.g. teamspaces that
# block integrations). Create one at https://www.notion.so/profile/integrations.
NOTION_API_TOKEN=

# Optional: keep a separate internal-integration (bot) token here for reference.
# ntn only reads NOTION_API_TOKEN; export this as NOTION_API_TOKEN to use it.
# NOTION_API_TOKEN_LEGACY=

# Optional overrides — uncomment if needed.
# NOTION_WORKSPACE_ID=        # pin a specific workspace (overrides default)
# NOTION_KEYRING=0            # use file-based auth (~/.config/notion/auth.json) instead of OS keychain
